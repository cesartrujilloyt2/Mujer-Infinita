<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tu Alma Ya Sabe Facturar Millones · Mujer Infinita</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    /* ADN visual Mujer Infinita */
    --rosa:#E25787;
    --rosa-deep:#C9446F;
    --rosa-soft:#FCE9F0;
    --dorado:#DCBB91;
    --dorado-deep:#B89668;
    --dorado-soft:#F5EBDA;
    --verde:#79A490;
    --verde-soft:#E8EFEA;
    --negro:#1A1A1A;
    --gris-claro:#F6F5F6;
    --crema:#FBF8F4;
    --blanco:#FFFFFF;
    --ink:#2A2A2A;
    --muted:#777777;
    --border:#EAE6E0;

    --display:'Cormorant Garamond', Georgia, serif;  /* Stand-in for The Seasons */
    --medium:'Libre Baskerville', Georgia, serif;
    --body:'Poppins', system-ui, sans-serif;
  }

  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    font-family:var(--body);
    color:var(--ink);
    background:var(--blanco);
    line-height:1.65;
    font-weight:300;
    font-size:16px;
    -webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;
    overflow-x:hidden;
  }

  img{max-width:100%;display:block;height:auto}

  /* ============ HEADER ============ */
  header{
    position:sticky;top:0;z-index:50;
    background:rgba(255,255,255,.94);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--border);
    padding:1rem 2rem;
  }
  .header-inner{
    max-width:1280px;margin:0 auto;
    display:flex;align-items:center;justify-content:space-between;gap:1.5rem;
  }
  .logo{height:34px;width:auto}
  .header-cta{
    font-family:var(--body);
    font-size:.78rem;
    letter-spacing:.16em;
    text-transform:uppercase;
    font-weight:500;
    color:var(--negro);
    text-decoration:none;
    border-bottom:1.5px solid var(--rosa);
    padding-bottom:2px;
    transition:color .25s;
  }
  .header-cta:hover{color:var(--rosa)}

  /* ============ CONTAINERS ============ */
  .container{max-width:1180px;margin:0 auto;padding:0 2rem}
  .container-narrow{max-width:880px;margin:0 auto;padding:0 2rem}
  .container-tight{max-width:680px;margin:0 auto;padding:0 2rem}

  /* ============ KICKER / MICRO ============ */
  .kicker{
    font-family:var(--body);
    font-size:.72rem;
    letter-spacing:.28em;
    text-transform:uppercase;
    font-weight:500;
    color:var(--dorado-deep);
  }
  .micro{
    font-family:var(--body);
    font-size:.78rem;
    letter-spacing:.18em;
    text-transform:uppercase;
    font-weight:500;
    color:var(--muted);
  }

  /* ============ BUTTONS ============ */
  .cta-btn{
    display:inline-block;
    background:var(--rosa);
    color:var(--blanco);
    font-family:var(--body);
    font-size:.85rem;
    letter-spacing:.14em;
    text-transform:uppercase;
    font-weight:500;
    padding:1.15rem 2.4rem;
    border:none;
    border-radius:50px;
    text-decoration:none;
    cursor:pointer;
    transition:all .3s ease;
    box-shadow:0 4px 24px rgba(226,87,135,.25);
  }
  .cta-btn:hover{
    background:var(--rosa-deep);
    transform:translateY(-2px);
    box-shadow:0 6px 28px rgba(226,87,135,.35);
  }
  .cta-btn-outline{
    display:inline-block;
    color:var(--negro);
    font-family:var(--body);
    font-size:.78rem;
    letter-spacing:.18em;
    text-transform:uppercase;
    font-weight:500;
    padding:.4rem 0;
    text-decoration:none;
    border-bottom:1.5px solid var(--rosa);
    transition:color .25s;
  }
  .cta-btn-outline:hover{color:var(--rosa)}

  /* ============ FORM ============ */
  .form-row{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:.75rem;
    max-width:560px;
    margin:1.5rem 0 .75rem;
  }
  .hero .form-row{margin:.85rem 0 .6rem}
  .hero .cta-btn{padding:.85rem 1.85rem;font-size:.78rem}
  .form-row input{
    background:var(--crema);
    border:1px solid var(--border);
    border-radius:50px;
    padding:1rem 1.35rem;
    font-family:var(--body);
    font-size:.95rem;
    font-weight:300;
    color:var(--negro);
    width:100%;
    transition:border .25s;
  }
  .hero .form-row input{padding:.7rem 1.1rem;font-size:.85rem}
  .form-row input:focus{
    outline:none;
    border-color:var(--rosa);
    background:var(--blanco);
  }
  .form-row input::placeholder{color:var(--muted)}

  /* ============ HERO ============ */
  .hero{
    padding:2rem 0 2.5rem;
    background:var(--blanco);
    position:relative;
  }
  .hero-grid{
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:4.5rem;
    align-items:stretch;
  }
  .hero-text{
    display:flex;
    flex-direction:column;
    justify-content:center;
  }
  .hero-kicker{
    display:flex;align-items:center;gap:.7rem;
    margin-bottom:1rem;
  }
  .hero-kicker .dot{
    width:6px;height:6px;border-radius:50%;
    background:var(--rosa);
    flex-shrink:0;
  }
  .hero-dates{
    font-family:var(--body);
    font-size:.82rem;
    color:var(--negro);
    font-weight:400;
    letter-spacing:.05em;
    margin-bottom:1rem;
  }
  .hero-dates strong{font-weight:500;color:var(--dorado-deep)}
  h1.hero-title{
    font-family:var(--display);
    font-weight:400;
    font-size:clamp(1.7rem, 2.9vw, 2.5rem);
    line-height:1.12;
    letter-spacing:-.01em;
    color:var(--negro);
    margin-bottom:1rem;
  }
  h1.hero-title em{
    font-style:italic;
    color:var(--rosa);
    font-weight:400;
  }
  h1.hero-title .gold-underline{
    position:relative;
    display:inline-block;
  }
  h1.hero-title .gold-underline::after{
    content:"";
    position:absolute;
    left:0;right:0;bottom:.05em;
    height:.42em;
    background:var(--dorado-soft);
    z-index:-1;
    border-radius:2px;
  }
  .hero-sub{
    font-family:var(--medium);
    font-size:.92rem;
    line-height:1.55;
    color:var(--ink);
    font-style:italic;
    font-weight:400;
    margin-bottom:1rem;
    max-width:540px;
  }
  .hero-intro{
    font-family:var(--body);
    font-size:.92rem;
    line-height:1.6;
    color:var(--muted);
    font-weight:300;
    margin-bottom:1rem;
    max-width:540px;
  }
  .hero-disclaimer{
    margin-top:1rem;
    padding:.75rem 1rem;
    background:var(--dorado-soft);
    border-left:3px solid var(--dorado);
    font-family:var(--body);
    font-size:.78rem;
    line-height:1.5;
    color:var(--negro);
    font-weight:400;
    max-width:540px;
    border-radius:0 6px 6px 0;
  }
  .hero-disclaimer strong{color:var(--rosa);font-weight:600}

  .hero-img{
    position:relative;
    height:100%;
    min-height:420px;
    overflow:hidden;
    border-radius:8px;
    box-shadow:0 30px 80px -30px rgba(26,26,26,.25);
  }
  .hero-img img{
    width:100%;height:100%;
    object-fit:cover;
  }
  .hero-img-tag{
    position:absolute;
    bottom:-16px;left:-16px;
    background:var(--blanco);
    padding:.65rem 1.15rem;
    border-radius:6px;
    font-family:var(--display);
    font-style:italic;
    font-size:1.15rem;
    color:var(--negro);
    box-shadow:0 12px 30px -8px rgba(0,0,0,.18);
    letter-spacing:.005em;
  }
  .hero-img-tag span{color:var(--rosa)}

  /* ============ TRUTH SECTION (pull) ============ */
  .truth{
    padding:7rem 0 6rem;
    background:var(--crema);
    position:relative;
  }
  .truth::before{
    content:"✦";
    position:absolute;
    top:3.5rem;left:50%;transform:translateX(-50%);
    font-size:1.6rem;
    color:var(--dorado);
    letter-spacing:.5em;
  }
  .truth-content{
    text-align:left;
    max-width:760px;
    margin:0 auto;
  }
  .truth-kicker{
    text-align:center;
    margin-bottom:2.5rem;
  }
  .truth-lead{
    font-family:var(--display);
    font-size:clamp(1.7rem, 3vw, 2.4rem);
    line-height:1.3;
    font-weight:400;
    color:var(--negro);
    margin-bottom:2rem;
    letter-spacing:-.005em;
  }
  .truth-lead em{font-style:italic;color:var(--rosa)}
  .truth-body{
    font-family:var(--body);
    font-size:1.05rem;
    line-height:1.85;
    color:var(--ink);
    font-weight:300;
    margin-bottom:1.4rem;
  }
  .truth-body strong{color:var(--negro);font-weight:500}
  .truth-stamp{
    margin-top:2.5rem;
    text-align:center;
    font-family:var(--display);
    font-style:italic;
    font-size:1.45rem;
    color:var(--dorado-deep);
    font-weight:500;
  }
  .truth-cta-wrap{
    text-align:center;
    margin-top:3rem;
  }

  /* ============ SECTION TITLE ============ */
  .section{padding:6rem 0}
  .section-alt{background:var(--crema)}
  .section-title-wrap{
    text-align:center;
    margin-bottom:3.5rem;
  }
  h2.section-title{
    font-family:var(--display);
    font-weight:400;
    font-size:clamp(2rem, 4vw, 3.2rem);
    line-height:1.1;
    color:var(--negro);
    margin:.6rem 0 1rem;
    letter-spacing:-.01em;
  }
  h2.section-title em{font-style:italic;color:var(--rosa)}
  .section-sub{
    font-family:var(--medium);
    font-style:italic;
    font-size:1.05rem;
    color:var(--muted);
    font-weight:400;
    max-width:600px;
    margin:0 auto;
  }

  /* ============ FOR-WHO ============ */
  .for-who-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:1.25rem;
    max-width:980px;
    margin:0 auto;
  }
  .for-who-item{
    background:var(--blanco);
    border:1px solid var(--border);
    border-radius:14px;
    padding:1.75rem 1.85rem;
    font-family:var(--body);
    font-size:.96rem;
    line-height:1.7;
    color:var(--ink);
    font-weight:300;
    transition:transform .35s ease, box-shadow .35s ease, border-color .35s ease;
    position:relative;
  }
  .for-who-item:hover{
    transform:translateY(-3px);
    box-shadow:0 18px 40px -20px rgba(0,0,0,.12);
    border-color:var(--rosa-soft);
  }
  .for-who-item::before{
    content:"✦";
    color:var(--rosa);
    font-size:1rem;
    margin-right:.55rem;
    line-height:1;
  }
  .for-who-cta{
    text-align:center;
    margin-top:3rem;
  }

  /* ============ MID FORM (Asegura tu cupo) ============ */
  .mid-form{
    padding:6rem 0;
    background:var(--blanco);
    position:relative;
    overflow:hidden;
  }
  .mid-form::before{
    content:"";
    position:absolute;
    top:0;left:0;right:0;height:1px;
    background:linear-gradient(90deg, transparent, var(--dorado), transparent);
  }
  .mid-form-inner{
    text-align:center;
    max-width:680px;
    margin:0 auto;
  }
  .mid-form-inner h2{
    font-family:var(--display);
    font-size:clamp(2rem, 4vw, 3rem);
    font-weight:400;
    color:var(--negro);
    margin-bottom:1rem;
    line-height:1.15;
  }
  .mid-form-inner h2 em{font-style:italic;color:var(--rosa)}
  .mid-form-inner .lead{
    font-family:var(--medium);
    font-style:italic;
    font-size:1.05rem;
    color:var(--ink);
    margin-bottom:1.25rem;
    line-height:1.6;
  }
  .mid-form-inner p.note{
    font-family:var(--body);
    font-size:.95rem;
    color:var(--muted);
    margin-bottom:1.5rem;
    font-weight:400;
  }
  .mid-form-inner .form-row{margin-left:auto;margin-right:auto}

  /* ============ DAYS ============ */
  .days-intro{
    text-align:center;
    margin-bottom:4rem;
  }
  .days-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:2rem;
    max-width:1080px;
    margin:0 auto;
  }
  .day{
    background:var(--blanco);
    border:1px solid var(--border);
    border-radius:18px;
    padding:2.5rem 2.25rem;
    transition:all .4s ease;
    position:relative;
    overflow:hidden;
  }
  .day:hover{
    border-color:var(--rosa-soft);
    box-shadow:0 30px 60px -30px rgba(226,87,135,.2);
    transform:translateY(-4px);
  }
  .day-header{
    display:flex;align-items:baseline;gap:1rem;
    margin-bottom:1.25rem;
    padding-bottom:1.25rem;
    border-bottom:1px solid var(--border);
  }
  .day-number{
    font-family:var(--display);
    font-size:3.6rem;
    font-weight:400;
    line-height:1;
    color:var(--dorado);
    font-style:italic;
    letter-spacing:-.02em;
  }
  .day-meta{
    font-family:var(--body);
    font-size:.72rem;
    letter-spacing:.22em;
    text-transform:uppercase;
    color:var(--muted);
    font-weight:500;
  }
  .day-meta strong{color:var(--negro);font-weight:500;display:block;margin-bottom:.15rem}
  h3.day-title{
    font-family:var(--display);
    font-weight:500;
    font-size:1.7rem;
    line-height:1.2;
    color:var(--negro);
    margin-bottom:.85rem;
    letter-spacing:-.005em;
  }
  h3.day-title em{font-style:italic;color:var(--rosa)}
  .day-desc{
    font-family:var(--body);
    font-size:.96rem;
    line-height:1.7;
    color:var(--ink);
    font-weight:300;
  }

  .day-finale{
    margin-top:3rem;
    padding:2.5rem 2.5rem;
    background:linear-gradient(135deg, var(--negro) 0%, #2d2d2d 100%);
    border-radius:18px;
    color:var(--blanco);
    text-align:center;
    max-width:1080px;
    margin-left:auto;margin-right:auto;
    margin-top:3rem;
    position:relative;
    overflow:hidden;
  }
  .day-finale::before{
    content:"";
    position:absolute;
    inset:0;
    background:radial-gradient(circle at 80% 20%, rgba(220,187,145,.12), transparent 50%);
  }
  .day-finale-kicker{
    font-family:var(--body);
    font-size:.72rem;
    letter-spacing:.28em;
    text-transform:uppercase;
    color:var(--dorado);
    font-weight:500;
    margin-bottom:1rem;
    position:relative;
  }
  .day-finale h3{
    font-family:var(--display);
    font-style:italic;
    font-size:clamp(1.6rem, 3vw, 2.4rem);
    font-weight:400;
    line-height:1.25;
    margin-bottom:1rem;
    position:relative;
  }
  .day-finale h3 strong{
    font-style:normal;
    font-weight:500;
    color:var(--dorado);
    letter-spacing:.04em;
  }
  .day-finale p{
    font-family:var(--medium);
    font-size:1rem;
    line-height:1.7;
    color:rgba(255,255,255,.85);
    max-width:640px;
    margin:0 auto;
    position:relative;
  }

  /* ============ BIO MARÍA ============ */
  .bio{
    padding:7rem 0;
    background:var(--blanco);
  }
  .bio-grid{
    display:grid;
    grid-template-columns:1fr 1.15fr;
    gap:5rem;
    align-items:center;
    max-width:1180px;
    margin:0 auto;
  }
  .bio-img-wrap{
    position:relative;
  }
  .bio-img-main{
    aspect-ratio:4/5;
    border-radius:8px;
    overflow:hidden;
    box-shadow:0 30px 60px -30px rgba(0,0,0,.25);
  }
  .bio-img-main img{
    width:100%;height:100%;
    object-fit:cover;
  }
  .bio-img-deco{
    position:absolute;
    bottom:-30px;right:-30px;
    width:42%;
    aspect-ratio:3/4;
    border-radius:6px;
    overflow:hidden;
    border:6px solid var(--blanco);
    box-shadow:0 18px 40px -10px rgba(0,0,0,.2);
  }
  .bio-img-deco img{
    width:100%;height:100%;
    object-fit:cover;
  }

  .bio-content .kicker{
    margin-bottom:.8rem;
  }
  h2.bio-title{
    font-family:var(--display);
    font-weight:400;
    font-size:clamp(2.2rem, 4.4vw, 3.4rem);
    line-height:1.05;
    color:var(--negro);
    margin-bottom:1.5rem;
    letter-spacing:-.012em;
  }
  h2.bio-title em{font-style:italic;color:var(--rosa)}

  .bio-body p{
    font-family:var(--body);
    font-size:1rem;
    line-height:1.8;
    color:var(--ink);
    font-weight:300;
    margin-bottom:1.1rem;
  }
  .bio-body p strong{color:var(--negro);font-weight:500}
  .bio-body p em{
    font-family:var(--display);
    font-style:italic;
    font-size:1.18em;
    color:var(--rosa);
    line-height:1.4;
    display:block;
    padding:.5rem 0;
  }
  .bio-body .pull{
    font-family:var(--display);
    font-style:italic;
    font-size:1.45rem;
    line-height:1.4;
    color:var(--negro);
    margin:2rem 0;
    padding-left:1.5rem;
    border-left:2px solid var(--dorado);
  }

  /* ============ FINAL CTA ============ */
  .final-cta{
    padding:7rem 0;
    background:var(--crema);
    position:relative;
    overflow:hidden;
  }
  .final-cta::before{
    content:"✦";
    position:absolute;
    top:3rem;left:50%;transform:translateX(-50%);
    font-size:1.4rem;
    color:var(--dorado);
  }
  .final-grid{
    display:grid;
    grid-template-columns:1fr 1.05fr;
    gap:5rem;
    align-items:center;
    max-width:1100px;
    margin:0 auto;
  }
  .final-img{
    aspect-ratio:4/5;
    border-radius:8px;
    overflow:hidden;
    box-shadow:0 30px 60px -30px rgba(0,0,0,.2);
  }
  .final-img img{
    width:100%;height:100%;
    object-fit:cover;
  }
  .final-text h2{
    font-family:var(--display);
    font-weight:400;
    font-size:clamp(2.2rem, 4.4vw, 3.2rem);
    line-height:1.1;
    color:var(--negro);
    margin-bottom:1.2rem;
    letter-spacing:-.01em;
  }
  .final-text h2 em{font-style:italic;color:var(--rosa)}
  .final-text p{
    font-family:var(--medium);
    font-style:italic;
    font-size:1.05rem;
    line-height:1.6;
    color:var(--ink);
    margin-bottom:1.8rem;
  }
  .final-text .form-row{margin:1.5rem 0}
  .final-text .closing{
    margin-top:1.5rem;
    font-family:var(--display);
    font-style:italic;
    font-size:1.3rem;
    color:var(--dorado-deep);
    font-weight:500;
  }

  /* ============ FOOTER ============ */
  footer{
    padding:3rem 0 2.5rem;
    background:var(--blanco);
    border-top:1px solid var(--border);
    text-align:center;
  }
  footer img{
    height:32px;width:auto;
    margin:0 auto 1.25rem;
    opacity:.85;
  }
  footer .copyright{
    font-family:var(--body);
    font-size:.78rem;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:var(--muted);
    font-weight:400;
  }

  /* ============ REVEAL ============ */
  .reveal{
    opacity:0;
    transform:translateY(28px);
    transition:opacity .9s ease, transform .9s ease;
  }
  .reveal.in{opacity:1;transform:translateY(0)}

  /* ============ RESPONSIVE ============ */
  @media (max-width: 980px){
    .container,.container-narrow,.container-tight{padding:0 1.5rem}
    .hero{padding:3rem 0 4rem}
    .hero-grid{grid-template-columns:1fr;gap:3rem}
    .hero-img-tag{font-size:1.15rem;left:1rem;bottom:-15px}
    .for-who-grid{grid-template-columns:1fr}
    .days-grid{grid-template-columns:1fr;gap:1.5rem}
    .day{padding:2rem 1.75rem}
    .day-number{font-size:2.8rem}
    .bio-grid{grid-template-columns:1fr;gap:3rem}
    .bio-img-deco{display:none}
    .final-grid{grid-template-columns:1fr;gap:3rem}
    .truth, .section{padding:4.5rem 0}
    .form-row{grid-template-columns:1fr}
    header{padding:.85rem 1.25rem}
    .logo{height:28px}
