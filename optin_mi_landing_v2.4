    .for-who-item p{font-size:.9rem}
    .photos-row{grid-template-columns:repeat(2, 1fr)}
    .photos-row img:nth-child(3){display:none}
    .bio-body .pull{font-size:1.15rem;padding:.85rem 1rem}
    .mid-form-card p.note strong{font-size:1.3rem}
  }
</style>
</head>
<body>

<!-- ============ ANNOUNCE BAR ============ -->
<div class="announce">
  Evento Gratuito · 4 Clases en Vivo · <strong>Exclusivo para Empresarias</strong>
</div>

<!-- ============ HEADER ============ -->
<header>
