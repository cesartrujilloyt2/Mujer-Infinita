    font-style:italic;
    font-size:1.2rem;
    color:var(--rosa);
    font-weight:500;
    line-height:1.4;
  }

  /* ============ FOOTER ============ */
  footer{
    padding:3rem 0 2.5rem;
    background:var(--negro);
    color:var(--crema);
    text-align:center;
  }
  footer img{
    height:32px;width:auto;
    margin:0 auto 1rem;
    opacity:.85;
    filter:brightness(0) invert(1) sepia(.3) saturate(.6);
  }
  footer .copyright{
    font-family:var(--body);
    font-size:.7rem;
    letter-spacing:.2em;
    text-transform:uppercase;
    color:rgba(245,239,230,.55);
    font-weight:400;
  }

  /* ============ REVEAL ============ */
  .reveal{
    opacity:0;
    transform:translateY(28px);
    transition:opacity .9s ease, transform .9s ease;
  }
  .reveal.in{opacity:1;transform:translateY(0)}

  /* ============ RESPONSIVE ============ */
  @media (max-width: 980px){
    .container{padding:0 1.25rem}
    .hero{padding:1.25rem 0 1.75rem}
    .hero-grid{grid-template-columns:1fr;gap:1.75rem}
    .hero-img{min-height:340px;aspect-ratio:4/3}
    .hero-text{padding-right:0}
    .hero-agenda{grid-template-columns:repeat(4, 1fr)}
    .agenda-num{font-size:1.3rem}

    .truth-card,
    .for-who-card,
    .mid-form-card,
    .days-card,
    .final-card{padding:2.5rem 1.5rem}

    .day-row{grid-template-columns:1fr;gap:1rem}
    .day-tag{display:flex;align-items:center;justify-content:flex-start;gap:.85rem;padding:.65rem 1rem;text-align:left}
    .day-tag-name{font-size:1.15rem;margin-bottom:0}
    .day-tag-date{font-size:.7rem}
    .day-tag-num{margin-bottom:0}

    .photos-row{grid-template-columns:repeat(3, 1fr)}
    .photos-row img:nth-child(4),
    .photos-row img:nth-child(5){display:none}

    .bio-card{grid-template-columns:1fr}
    .bio-img{min-height:380px;aspect-ratio:4/3}
    .bio-content{padding:2.5rem 1.75rem}
    .bio-stats{grid-template-columns:1fr;gap:.75rem}
    .bio-stat{display:flex;justify-content:space-between;align-items:center;text-align:left}

    .truth, .for-who, .mid-form, .days, .bio, .final-cta{padding:3rem 0}
    .photo-strip{padding:2rem 0}
    .form-row{grid-template-columns:1fr}
    header{padding:.85rem 1.25rem}
    .logo{height:28px}
    .announce{font-size:.65rem;letter-spacing:.16em;padding:.7rem 1rem}
  }

  @media (max-width: 580px){
    h1.hero-title{font-size:1.7rem}
    .agenda-box{padding:.5rem .25rem}
    .agenda-num{font-size:1.1rem}
    .agenda-label{font-size:.5rem}
    h2.section-title{font-size:1.85rem}
    .truth-card h2{font-size:1.4rem}
    .truth-stamp{font-size:1.3rem;padding:1rem 1.25rem}
