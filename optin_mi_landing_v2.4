    padding:4rem 3rem;
    max-width:920px;
    margin:0 auto;
    box-shadow:var(--shadow-lg);
    text-align:center;
  }
  .final-card .kicker{margin-bottom:.85rem;display:inline-block}
  .final-card h2{
    font-family:var(--display);
    font-weight:500;
    font-size:clamp(2rem, 4.4vw, 3.2rem);
    line-height:1.08;
    color:var(--negro);
    margin-bottom:1.25rem;
    letter-spacing:-.012em;
  }
  .final-card h2 em{font-style:italic;color:var(--rosa);font-weight:600}
  .final-card > p{
    font-family:var(--medium);
    font-style:italic;
    font-size:1.05rem;
    line-height:1.6;
    color:var(--ink);
