
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tu Alma Ya Sabe Facturar Millones · Mujer Infinita</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --rosa:#E25787;
    --rosa-deep:#C9446F;
    --rosa-soft:#FCE9F0;
    --rosa-peach:#FADADF;        /* fondo dominante */
    --rosa-peach-deep:#F4C8CE;
    --rosa-peach-soft:#FDEEEF;
    --dorado:#DCBB91;
    --dorado-deep:#B89668;
    --dorado-soft:#F5EBDA;
    --negro:#1A1A1A;
    --crema:#FBF8F4;
    --blanco:#FFFFFF;
    --ink:#2A2A2A;
    --muted:#7A7A7A;
    --border:#EAE6E0;

    --display:'Cormorant Garamond', Georgia, serif;
    --medium:'Libre Baskerville', Georgia, serif;
    --body:'Poppins', system-ui, sans-serif;

    --shadow-sm:0 2px 12px -4px rgba(180,80,110,.08);
    --shadow-md:0 18px 40px -20px rgba(180,80,110,.18);
    --shadow-lg:0 30px 70px -30px rgba(180,80,110,.25);
  }

  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    font-family:var(--body);
    color:var(--ink);
    background:var(--rosa-peach);
    line-height:1.65;
    font-weight:300;
    font-size:16px;
    -webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;
    overflow-x:hidden;
  }

  img{max-width:100%;display:block;height:auto}

  /* ============ TOP ANNOUNCEMENT BAR ============ */
  .announce{
    background:var(--negro);
    color:var(--crema);
    padding:.85rem 1.5rem;
    text-align:center;
    font-family:var(--body);
    font-size:.74rem;
    letter-spacing:.22em;
    text-transform:uppercase;
    font-weight:500;
    line-height:1.5;
  }
  .announce strong{color:var(--rosa-peach);font-weight:600}

  /* ============ HEADER ============ */
  header{
    position:sticky;top:0;z-index:50;
    background:rgba(250,218,223,.92);
    backdrop-filter:blur(12px);
    border-bottom:1px solid rgba(180,80,110,.12);
    padding:1rem 2rem;
  }
  .header-inner{
    max-width:1280px;margin:0 auto;
    display:flex;align-items:center;justify-content:space-between;gap:1.5rem;
  }
  .logo{height:34px;width:auto}
  .header-cta{
    font-family:var(--body);
    font-size:.74rem;
    letter-spacing:.18em;
    text-transform:uppercase;
    font-weight:600;
    color:var(--blanco);
    text-decoration:none;
    background:var(--rosa);
    padding:.6rem 1.2rem;
    border-radius:6px;
    transition:all .25s;
    box-shadow:var(--shadow-sm);
  }
  .header-cta:hover{
    background:var(--rosa-deep);
    transform:translateY(-1px);
  }

  /* ============ CONTAINERS ============ */
  .container{max-width:1240px;margin:0 auto;padding:0 1.5rem;position:relative}

  /* ============ KICKER ============ */
  .kicker{
    font-family:var(--body);
    font-size:.7rem;
    letter-spacing:.32em;
    text-transform:uppercase;
    font-weight:600;
    color:var(--rosa);
  }
  .kicker-dark{color:var(--negro)}

  /* ============ BUTTONS ============ */
  .cta-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:.5rem;
    background:linear-gradient(180deg, var(--rosa) 0%, var(--rosa-deep) 100%);
    color:var(--blanco);
    font-family:var(--body);
    font-size:.85rem;
    letter-spacing:.16em;
    text-transform:uppercase;
    font-weight:700;
    padding:1.15rem 2.4rem;
    border:none;
    border-radius:8px;
    text-decoration:none;
    cursor:pointer;
    transition:all .3s ease;
    box-shadow:0 8px 18px -8px rgba(226,87,135,.55), inset 0 -2px 0 rgba(0,0,0,.08);
    position:relative;
    z-index:2;
  }
  .cta-btn:hover{
    transform:translateY(-2px);
    box-shadow:0 12px 22px -8px rgba(226,87,135,.65), inset 0 -2px 0 rgba(0,0,0,.08);
  }
  .cta-btn .arrow{transition:transform .3s}
  .cta-btn:hover .arrow{transform:translateX(3px)}
  .cta-btn-sub{
    display:block;
    font-family:var(--body);
    font-size:.6rem;
    font-weight:400;
    letter-spacing:.2em;
    margin-top:.2rem;
    opacity:.85;
    text-transform:none;
  }

  /* ============ FORM ============ */
  .form-row{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:.75rem;
    max-width:560px;
    margin:1.25rem 0 .85rem;
  }
  .form-row input{
    background:var(--blanco);
    border:1px solid var(--border);
    border-radius:8px;
    padding:.95rem 1.25rem;
    font-family:var(--body);
    font-size:.9rem;
    font-weight:400;
    color:var(--negro);
    width:100%;
    transition:all .25s;
  }
  .form-row input:focus{
    outline:none;
    border-color:var(--rosa);
    box-shadow:0 0 0 3px rgba(226,87,135,.12);
  }
  .form-row input::placeholder{color:var(--muted)}
  .hero .form-row{margin:.65rem 0 .55rem}
  .hero .form-row input{padding:.65rem 1rem;font-size:.82rem}
  .hero .cta-btn{padding:.8rem 1.85rem;font-size:.74rem}

  /* ============ HERO ============ */
  .hero{
    padding:1rem 0 1.75rem;
    background:var(--rosa-peach);
    position:relative;
  }
  .hero-grid{
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:3.5rem;
    align-items:stretch;
  }
  .hero-text{
    display:flex;
    flex-direction:column;
    justify-content:center;
    padding-right:1rem;
  }
  .hero-kicker{margin-bottom:.6rem;display:inline-block}
  .hero-dates{
    font-family:var(--medium);
    font-size:.78rem;
    color:var(--negro);
    font-weight:700;
    margin-bottom:.7rem;
    letter-spacing:.04em;
  }
  .hero-dates strong{color:var(--rosa);font-weight:700}

  h1.hero-title{
    font-family:var(--display);
    font-weight:500;
    font-size:clamp(1.65rem, 2.9vw, 2.4rem);
    line-height:1.12;
    letter-spacing:-.012em;
    color:var(--negro);
    margin-bottom:.85rem;
  }
  h1.hero-title em{
    font-style:italic;
    color:var(--rosa);
    font-weight:600;
  }

  .hero-sub{
    font-family:var(--medium);
    font-size:.85rem;
    line-height:1.55;
    color:var(--ink);
    margin-bottom:.85rem;
    max-width:540px;
    font-weight:400;
  }

  /* Agenda visual hero (4 clases) */
  .hero-agenda{
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:.45rem;
    margin:.75rem 0 .85rem;
    max-width:540px;
  }
  .agenda-box{
    background:var(--blanco);
    border:1px solid rgba(180,80,110,.15);
    border-radius:8px;
    padding:.5rem .25rem;
    text-align:center;
    box-shadow:var(--shadow-sm);
  }
  .agenda-num{
    font-family:var(--display);
    font-style:italic;
    font-size:1.35rem;
    color:var(--rosa);
    font-weight:600;
    line-height:.95;
    margin-bottom:.05rem;
  }
  .agenda-label{
    font-family:var(--body);
    font-size:.5rem;
    letter-spacing:.18em;
    text-transform:uppercase;
    color:var(--muted);
    font-weight:600;
  }

  .hero-disclaimer{
    margin-top:.75rem;
    padding:.65rem 1rem;
    background:var(--blanco);
    border-radius:8px;
    font-family:var(--body);
    font-size:.74rem;
    line-height:1.5;
    color:var(--negro);
    font-weight:400;
    max-width:540px;
    box-shadow:var(--shadow-sm);
    border-left:3px solid var(--rosa);
  }
  .hero-disclaimer strong{color:var(--rosa);font-weight:700}

  .hero-img-wrap{
    position:relative;
  }
  .hero-img{
    position:relative;
    height:100%;
    min-height:380px;
    overflow:hidden;
    border-radius:14px;
    box-shadow:var(--shadow-lg);
  }
  .hero-img img{
    width:100%;height:100%;
    object-fit:cover;
  }
  .hero-img-tag{
    position:absolute;
    bottom:1rem;left:1rem;
    background:var(--blanco);
    padding:.5rem .9rem;
    border-radius:6px;
    box-shadow:var(--shadow-md);
    z-index:2;
  }
  .hero-img-tag-name{
    font-family:var(--display);
    font-style:italic;
    font-size:1.05rem;
    color:var(--negro);
    line-height:1.1;
    font-weight:600;
  }
  .hero-img-tag-role{
    font-family:var(--body);
    font-size:.52rem;
    letter-spacing:.22em;
    text-transform:uppercase;
    color:var(--rosa);
    font-weight:600;
    margin-top:.12rem;
  }

  /* ============ TRUTH (card flotante) ============ */
  .truth{
    padding:4rem 0 5rem;
    background:var(--rosa-peach);
  }
  .truth-card{
    background:var(--blanco);
    border-radius:18px;
    padding:4rem 3rem;
    max-width:780px;
    margin:0 auto;
    box-shadow:var(--shadow-lg);
    text-align:center;
    position:relative;
  }
  .truth-eyebrow{
    margin-bottom:1.5rem;
  }
  .truth-card h2{
    font-family:var(--display);
    font-size:clamp(1.7rem, 3vw, 2.4rem);
    line-height:1.18;
    font-weight:500;
    color:var(--negro);
    margin-bottom:2rem;
    letter-spacing:-.005em;
  }
  .truth-card h2 em{font-style:italic;color:var(--rosa);font-weight:600}
  .truth-body{
    font-family:var(--body);
    font-size:1rem;
    line-height:1.85;
    color:var(--ink);
    font-weight:300;
    margin-bottom:1.3rem;
    text-align:left;
  }
  .truth-body strong{color:var(--negro);font-weight:600}
  .truth-stamp{
    margin:2rem auto;
    padding:1.25rem 2rem;
    background:var(--rosa-peach-soft);
    border-radius:10px;
    font-family:var(--display);
    font-style:italic;
    font-size:1.6rem;
    color:var(--rosa);
    font-weight:600;
    line-height:1.2;
    max-width:480px;
  }
  .truth-final{
    font-family:var(--display);
    font-style:italic;
    font-size:1.3rem;
    color:var(--rosa);
    text-align:center;
    margin:2rem 0;
    font-weight:500;
  }
  .truth-cta-wrap{margin-top:2rem}

  /* ============ FOR-WHO (card grande con grid interno) ============ */
  .for-who{
    padding:5rem 0;
    background:var(--rosa-peach-deep);
  }
  .for-who-card{
    background:var(--blanco);
    border-radius:18px;
    padding:4rem 3rem;
    max-width:1080px;
    margin:0 auto;
    box-shadow:var(--shadow-lg);
  }
  .for-who-header{
    text-align:center;
    margin-bottom:3rem;
  }
  .for-who-header .kicker{margin-bottom:.75rem;display:inline-block}
  h2.section-title{
    font-family:var(--display);
    font-weight:500;
    font-size:clamp(2rem, 4.2vw, 3.2rem);
    line-height:1.05;
    color:var(--negro);
    letter-spacing:-.012em;
    margin-bottom:.5rem;
  }
  h2.section-title em{font-style:italic;color:var(--rosa);font-weight:600}
  h2.section-title.upper{text-transform:uppercase;letter-spacing:.005em}

  .for-who-list{
    display:grid;
    gap:.85rem;
    max-width:880px;
    margin:0 auto;
  }
  .for-who-item{
    display:grid;
    grid-template-columns:50px 1fr;
    gap:1.25rem;
    padding:1.4rem 1.6rem;
    background:var(--rosa-peach-soft);
    border-radius:12px;
    align-items:center;
    transition:all .35s ease;
  }
  .for-who-item:hover{
    background:var(--blanco);
    box-shadow:var(--shadow-md);
    transform:translateX(4px);
  }
  .for-who-num{
    width:42px;height:42px;
    background:var(--rosa);
    color:var(--blanco);
    border-radius:50%;
    display:grid;place-items:center;
    font-family:var(--display);
    font-style:italic;
    font-size:1.3rem;
    font-weight:600;
    flex-shrink:0;
  }
  .for-who-item p{
    font-family:var(--body);
    font-size:.95rem;
    line-height:1.7;
    color:var(--ink);
    font-weight:300;
  }
  .for-who-cta{
    text-align:center;
    margin-top:2.5rem;
  }

  /* ============ MID FORM ============ */
  .mid-form{
    padding:5rem 0;
    background:var(--rosa-peach);
    text-align:center;
  }
  .mid-form-card{
    background:var(--blanco);
    border-radius:18px;
    padding:3.5rem 3rem;
    max-width:680px;
    margin:0 auto;
    box-shadow:var(--shadow-lg);
  }
  .mid-form-card h2{
    font-family:var(--display);
    font-size:clamp(2rem, 4vw, 2.85rem);
    font-weight:500;
    color:var(--negro);
    margin-bottom:1rem;
    line-height:1.1;
  }
  .mid-form-card h2 em{font-style:italic;color:var(--rosa);font-weight:600}
  .mid-form-card .lead{
    font-family:var(--medium);
    font-style:italic;
    font-size:1.05rem;
    color:var(--ink);
    margin-bottom:1.25rem;
    line-height:1.6;
  }
  .mid-form-card p.note{
    font-family:var(--body);
    font-size:.9rem;
    color:var(--muted);
    margin-bottom:1.5rem;
    font-weight:400;
  }
  .mid-form-card p.note strong{
    display:block;
    font-family:var(--display);
    font-style:italic;
    font-size:1.55rem;
    color:var(--rosa);
    font-weight:600;
    letter-spacing:.005em;
    margin-top:.5rem;
    line-height:1.2;
  }
  .mid-form-card .form-row{margin-left:auto;margin-right:auto}

  /* ============ DAYS (card grande con tabla de 4 clases) ============ */
  .days{
    padding:5rem 0;
    background:var(--rosa-peach);
  }
  .days-card{
    background:var(--blanco);
    border-radius:18px;
    padding:4rem 3rem;
    max-width:1080px;
    margin:0 auto;
    box-shadow:var(--shadow-lg);
  }
  .days-header{
    text-align:center;
    margin-bottom:3rem;
  }
  .days-header .kicker{margin-bottom:.75rem;display:inline-block}

  .days-list{
    display:grid;
    gap:1rem;
    max-width:920px;
    margin:0 auto;
  }
  .day-row{
    display:grid;
    grid-template-columns:140px 1fr;
    gap:1.5rem;
    padding:1.5rem;
    background:var(--rosa-peach-soft);
    border-radius:12px;
    align-items:center;
    transition:all .35s ease;
  }
  .day-row:hover{
    background:var(--blanco);
    box-shadow:var(--shadow-md);
  }
  .day-tag{
    background:var(--rosa);
    color:var(--blanco);
    padding:.85rem .85rem;
    border-radius:8px;
    text-align:center;
  }
  .day-tag-num{
    font-family:var(--body);
    font-size:.65rem;
    letter-spacing:.22em;
    text-transform:uppercase;
    font-weight:700;
    margin-bottom:.15rem;
    opacity:.9;
  }
  .day-tag-name{
    font-family:var(--display);
    font-weight:600;
    font-size:1.4rem;
    line-height:1;
    margin-bottom:.25rem;
  }
  .day-tag-date{
    font-family:var(--body);
    font-size:.7rem;
    letter-spacing:.06em;
    font-weight:500;
    opacity:.95;
  }
  .day-content h3{
    font-family:var(--display);
    font-weight:500;
    font-size:1.35rem;
    line-height:1.2;
    color:var(--negro);
    margin-bottom:.4rem;
    letter-spacing:-.005em;
  }
  .day-content h3 em{font-style:italic;color:var(--rosa);font-weight:600}
  .day-content p{
    font-family:var(--body);
    font-size:.92rem;
    line-height:1.65;
    color:var(--ink);
    font-weight:300;
  }

  /* Day finale (presentación de programa) */
  .day-finale{
    margin-top:2rem;
    padding:2.25rem 2rem;
    background:linear-gradient(135deg, var(--negro) 0%, #2a2a2a 100%);
    border-radius:14px;
    color:var(--blanco);
    text-align:center;
    position:relative;
    overflow:hidden;
  }
  .day-finale::before{
    content:"";
    position:absolute;
    inset:.85rem;
    border:1px solid rgba(220,187,145,.25);
    border-radius:8px;
    pointer-events:none;
  }
  .day-finale-kicker{
    font-family:var(--body);
    font-size:.7rem;
    letter-spacing:.32em;
    text-transform:uppercase;
    color:var(--dorado);
    font-weight:700;
    margin-bottom:.85rem;
    position:relative;
  }
  .day-finale h3{
    font-family:var(--display);
    font-weight:500;
    font-size:clamp(1.6rem, 3vw, 2.2rem);
    line-height:1.2;
    margin-bottom:1rem;
    letter-spacing:-.008em;
    position:relative;
  }
  .day-finale h3 .program{
    font-style:italic;
    color:var(--dorado);
    font-weight:600;
    letter-spacing:.04em;
  }
  .day-finale p{
    font-family:var(--medium);
    font-style:italic;
    font-size:.95rem;
    line-height:1.7;
    color:rgba(255,255,255,.85);
    max-width:580px;
    margin:0 auto;
    position:relative;
  }

  /* ============ PHOTO STRIP ============ */
  .photo-strip{
    padding:3rem 0;
    background:var(--rosa-peach);
  }
  .photo-strip-inner{
    max-width:1240px;
    margin:0 auto;
    padding:0 1.5rem;
    text-align:center;
  }
  .photo-strip-eyebrow{
    margin-bottom:1.5rem;
  }
  .photo-strip-eyebrow .label{
    font-family:var(--display);
    font-style:italic;
    font-size:1.5rem;
    color:var(--rosa);
    font-weight:500;
    line-height:1.2;
  }
  .photos-row{
    display:grid;
    grid-template-columns:repeat(5, 1fr);
    gap:.65rem;
    border-radius:14px;
    overflow:hidden;
    box-shadow:var(--shadow-md);
  }
  .photos-row img{
    aspect-ratio:3/4;
    object-fit:cover;
    width:100%;
    height:100%;
  }

  /* ============ BIO (card grande) ============ */
  .bio{
    padding:5rem 0;
    background:var(--rosa-peach-deep);
  }
  .bio-card{
    background:var(--blanco);
    border-radius:18px;
    padding:0;
    overflow:hidden;
    max-width:1180px;
    margin:0 auto;
    box-shadow:var(--shadow-lg);
    display:grid;
    grid-template-columns:.85fr 1.15fr;
  }
  .bio-img{
    position:relative;
    overflow:hidden;
    min-height:560px;
  }
  .bio-img img{
    width:100%;height:100%;
    object-fit:cover;
  }
  .bio-content{
    padding:3.5rem 3rem;
  }
  .bio-content .kicker{margin-bottom:.5rem;display:inline-block}
  h2.bio-title{
    font-family:var(--display);
    font-weight:500;
    font-size:clamp(2rem, 4vw, 2.85rem);
    line-height:1.05;
    color:var(--rosa);
    margin-bottom:1.5rem;
    letter-spacing:.005em;
    text-transform:uppercase;
  }
  h2.bio-title em{
    font-style:italic;
    color:var(--negro);
    font-weight:500;
    text-transform:none;
  }

  .bio-body p{
    font-family:var(--body);
    font-size:.95rem;
    line-height:1.85;
    color:var(--ink);
    font-weight:300;
    margin-bottom:1rem;
  }
  .bio-body p strong{color:var(--negro);font-weight:600}
  .bio-body .pull{
    font-family:var(--display);
    font-style:italic;
    font-size:1.4rem;
    line-height:1.35;
    color:var(--rosa);
    font-weight:500;
    margin:1.5rem 0;
    padding:1.1rem 1.4rem;
    background:var(--rosa-peach-soft);
    border-radius:10px;
    border-left:3px solid var(--rosa);
  }
  .bio-stats{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:1rem;
    margin:1.5rem 0;
    padding:1.25rem 0;
    border-top:1px solid var(--border);
    border-bottom:1px solid var(--border);
  }
  .bio-stat{
    text-align:center;
  }
  .bio-stat-num{
    font-family:var(--display);
    font-weight:600;
    font-size:1.45rem;
    color:var(--rosa);
    line-height:1;
    margin-bottom:.2rem;
    font-style:italic;
  }
  .bio-stat-label{
    font-family:var(--body);
    font-size:.66rem;
    letter-spacing:.18em;
    text-transform:uppercase;
    color:var(--muted);
