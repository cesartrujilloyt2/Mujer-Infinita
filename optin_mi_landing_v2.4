            <div class="agenda-label">Día 2</div>
          </div>
          <div class="agenda-box">
            <div class="agenda-num">03</div>
            <div class="agenda-label">Día 3</div>
          </div>
          <div class="agenda-box">
            <div class="agenda-num">04</div>
            <div class="agenda-label">Día 4</div>
          </div>
        </div>

        <form class="form-row" onsubmit="return false">
          <input type="text" placeholder="Nombre" aria-label="Nombre">
          <input type="email" placeholder="Email" aria-label="Email">
        </form>
        <a href="#registro" class="cta-btn">Quiero mi cupo · Es gratis <span class="arrow">→</span></a>
        <div class="hero-disclaimer">
          En este evento revelaré por primera vez mi nuevo programa <strong>MUJER INFINITA</strong>, con la oportunidad de unirte, disponible únicamente para quienes estén presentes en las clases.
        </div>
      </div>

      <div class="hero-img-wrap reveal">
        <div class="hero-img">
          <img src="data:image/jpeg;base64," alt="María Montemayor">
        </div>
        <div class="hero-img-tag">
          <div class="hero-img-tag-name">María Montemayor</div>
