<!-- ============ FOOTER ============ -->
<footer>
  <img src="data:image/png;base64," alt="Mujer Infinita">
  <div class="copyright">© 2026 María Montemayor · Todos los derechos reservados</div>
</footer>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        io.unobserve(e.target);
      }
    });
  }, { threshold: .12, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>

