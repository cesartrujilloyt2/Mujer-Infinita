      <p class="note">Completa el formulario y reserva tu lugar en <strong>Tu Alma Ya Sabe Facturar Millones</strong></p>
      <form class="form-row" onsubmit="return false">
        <input type="text" placeholder="Nombre" aria-label="Nombre">
        <input type="email" placeholder="Email" aria-label="Email">
      </form>
      <a href="#registro" class="cta-btn">Quiero participar <span class="arrow">→</span></a>
    </div>
  </div>
</section>

<!-- ============ DAYS (4 clases en card-tabla) ============ -->
<section class="days">
  <div class="container">
